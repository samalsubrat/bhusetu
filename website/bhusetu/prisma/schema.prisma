// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  AGRICULTURAL
  APARTMENT
  VILLA
  OPEN_PLOT
  ROW_HOUSE
}

enum PropertyStatus {
  PENDING
  UNDER_REVIEW
  VERIFIED
  REGISTERED
  REJECTED
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum RegistrationStatus {
  DRAFT              // User started but hasn't paid
  PENDING_PAYMENT    // Payment failed / incomplete — 3-day window
  PENDING_RI_VERIFICATION    // Payment done, awaiting RI verification
  PENDING_ADDL_TAHASILDAR    // Verified by RI, awaiting Addl Tahasildar
  VERIFIED           // Approved → BHU Property ID minted on-chain
  REJECTED           // Rejected
}

enum UserRole {
  CITIZEN               // default for all new signups
  REVENUE_INSPECTOR
  ADDITIONAL_TAHASILDAR
  TAHASILDAR
  COLLECTOR
  ADMIN
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  role          UserRole  @default(CITIZEN)
  isVerified    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  otps            Otp[]
  sessions        Session[]
  properties      Property[]
  transactions    Transaction[] @relation("BuyerTransactions")
  registrations   Registration[]

  @@map("users")
}

model Otp {
  id        String   @id @default(cuid())
  code      String   // hashed OTP
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("otps")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model Property {
  id           String         @id @default(cuid())
  bhuSetuId    String         @unique // e.g. BHU-9928-X
  title        String
  description  String?
  type         PropertyType
  status       PropertyStatus @default(PENDING)

  // Area & Price
  areaSqFt     Float
  priceInPaise BigInt         // stored in paise to avoid float issues

  // Location
  state        String
  district     String
  taluka       String?
  village      String?
  surveyNumber String?
  latitude     Float?
  longitude    Float?
  geoJson      Json?          // GIS polygon data

  // Owner
  ownerId      String
  owner        User           @relation(fields: [ownerId], references: [id])

  // Timestamps
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  documents    Document[]
  listings     PropertyListing[]
  transactions Transaction[]

  @@index([ownerId])
  @@index([status])
  @@index([type])
  @@map("properties")
}

model Document {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  name        String   // e.g. "Sale Deed", "Encumbrance Certificate"
  cid         String   // IPFS CID from Pinata
  mimeType    String?
  sizeBytes   Int?

  createdAt   DateTime @default(now())

  @@index([propertyId])
  @@map("documents")
}

model PropertyListing {
  id           String   @id @default(cuid())
  propertyId   String
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  listedPriceInPaise BigInt
  isActive     Boolean  @default(true)
  listedAt     DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions Transaction[]

  @@index([propertyId])
  @@index([isActive])
  @@map("property_listings")
}

model Transaction {
  id              String            @id @default(cuid())
  razorpayOrderId String            @unique
  razorpayPaymentId String?
  razorpaySignature String?

  propertyId  String
  property    Property         @relation(fields: [propertyId], references: [id])

  listingId   String?
  listing     PropertyListing? @relation(fields: [listingId], references: [id])

  buyerId     String
  buyer       User             @relation("BuyerTransactions", fields: [buyerId], references: [id])

  amountInPaise BigInt
  status        TransactionStatus @default(PENDING)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([propertyId])
  @@index([buyerId])
  @@index([status])
  @@map("transactions")
}

model Registration {
  id               String             @id @default(cuid())
  regYear          Int                // e.g. 2026
  regNumber        Int                // sequential within year, 1–99999
  bhuSetuId        String?            @unique // null until smart contract execution post-verification

  // Status & lifecycle
  status           RegistrationStatus @default(DRAFT)
  paymentDeadline  DateTime?          // set when status = PENDING_PAYMENT (3-day window)

  // Owner
  userId           String
  user             User               @relation(fields: [userId], references: [id])

  // Property details
  ownerName        String
  landArea         Float              // sqft
  taxPaid          Boolean            @default(false)
  category         String             // Residential, Commercial, etc.

  // Boundaries
  northBoundary    String
  southBoundary    String
  eastBoundary     String
  westBoundary     String

  // Location
  pincode          String
  state            String
  district         String
  postOffice       String
  tehsil           String
  plotNumber       String

  // Documents (Pinata CIDs stored as JSON array)
  documents        Json               @default("[]")

  // Fee snapshot at time of registration
  processingFee    Int                @default(0) // in rupees
  stampDuty        Int                @default(0) // in rupees
  totalAmount      Int                @default(0) // in rupees

  // Razorpay references (set after payment)
  razorpayOrderId  String?
  razorpayPaymentId String?

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@unique([regYear, regNumber])
  @@index([userId])
  @@index([status])
  @@map("registrations")
}
